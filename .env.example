VITE_API_URL=http://localhost:5000/api

# Admin accounts (seeded on startup — no signup)
# Two admins, same initial password (each can change theirs later via Forgot password):
AUTH_EMAILS=admin@example.com,coach@example.com
AUTH_PASSWORD=change_me

# Or per-admin passwords: email:password pairs
# AUTH_ADMINS=admin@example.com:pass1,coach@example.com:pass2

# Or a single admin:
# AUTH_EMAIL=admin@example.com
# AUTH_PASSWORD=change_me

JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:3000

# SMTP for forgot-password emails (optional in dev — link is logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="PeakPerformance <your_email@gmail.com>"
